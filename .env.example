# ==============================================
# HUNTER TRADES - Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your values

# Node Environment (development | production | test)
NODE_ENV=development
PORT=5000

# ==============================================
# DATABASE
# ==============================================
# MongoDB connection string (use MongoDB Atlas or local MongoDB)
DATABASE_URL=mongodb://localhost:27017
DATABASE_NAME=journal_trade_dev

# ==============================================
# AUTHENTICATION (Better Auth + Discord OAuth)
# ==============================================
# Generate a random secret for Better Auth (use: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-random-secret-here
BETTER_AUTH_URL=http://localhost:5000

# Discord OAuth Application
# Create app at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_GUILD_ID=your-discord-server-id

# ==============================================
# FRONTEND
# ==============================================
FRONTEND_URL=http://localhost:3000

# ==============================================
# AI PROVIDERS (At least one required)
# ==============================================

# --- Google Gemini (Recommended for free tier) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic Claude (via OpenRouter or direct) ---
ANTHROPIC_AUTH_TOKEN=your-anthropic-token
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=anthropic/claude-3-5-haiku-latest

# --- Alibaba DashScope (Qwen models) ---
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-max

# --- Groq (Free tier available) ---
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# ==============================================
# FINANCIAL DATA API KEYS (Optional but recommended)
# ==============================================

# FRED API for US economic data (Liquidity Flow / ON RRP)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# Trading Economics API for PMI data
# Get key at: https://tradingeconomics.com/api
TE_API_KEY=your-trading-economics-key

# Alpha Vantage for economic indicators
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Twelve Data for real-time quotes and economic data
# Get free key at: https://twelvedata.com/apikey
TWELVE_DATA_API_KEY=your-twelve-data-key

# Finnhub for market data
# Get free key at: https://finnhub.io/register
FINNHUB_API_KEY=your-finnhub-key

# ==============================================
# MCP (Model Context Protocol) SERVERS (Optional)
# ==============================================

# FlowLLM Finance MCP Server
FLOW_LLM_API_KEY=your-flow-llm-key
TUSHARE_API_TOKEN=your-tushare-token
TAVILY_API_KEY=your-tavily-key

# Aitrados Trading AI Agents MCP Server
AITRADOS_SECRET_KEY=your-aitrados-key

# ==============================================
# ADVANCED CONFIGURATION (Optional)
# ==============================================

# Manual CPI override (in percent, e.g., 4.2)
# MACRO_CPI_YOY_OVERRIDE=4.2

# 9Router Configuration
# NINE_ROUTER_URL=your-9router-url
# NINE_ROUTER_API_KEY=your-9router-key
