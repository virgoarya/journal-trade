import puppeteer from "puppeteer";
import { silentLogger } from "./silent-logger";

async function scrapeTradingViewActual(
  eventName: string,
  country?: string
): Promise<string | null> {
  let browser: puppeteer.Browser | null = null;

  try {
    browser = await puppeteer.launch({
      headless: true,
      args: [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-web-security",
        "--disable-features=IsolateOrigins,site-per-file-origin-trials",
      ],
    });

    const page = await browser.newPage();

    await page.setUserAgent(
      "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    );

    await page.setExtraHTTPHeaders({
      "Accept-Language": "en-US,en;q=0.9",
    });

    await page.goto("https://www.tradingview.com/economic-calendar/", {
      waitUntil: "networkidle2",
      timeout: 30000,
    });

    await page.waitForSelector(".economic-calendar-table, .tv-economic-calendar, table", {
      timeout: 15000,
    });

    const actual = await page.evaluate(
      (eventName, country) => {
        const rows = document.querySelectorAll("tr");
        const eventLower = eventName.toLowerCase();
        const countryLower = (country || "").toLowerCase();

        for (const row of rows) {
          const cells = row.querySelectorAll("td");
          if (cells.length < 5) continue;

          const rowText = row.textContent?.toLowerCase() || "";

          if (!rowText.includes(eventLower)) continue;

          if (country && !rowText.includes(countryLower)) continue;

          // Actual value is typically in the 4th or 5th column
          const actualIndex = Array.from(cells).findIndex(
            (c) => {
              const txt = c.textContent?.toLowerCase() || "";
              return (
                txt.includes("actual") ||
                (cells[3] && c === cells[3]) ||
                (cells[4] && c === cells[4])
              );
            }
          );

          const actualCell = actualIndex >= 0 ? cells[actualIndex] : 
                           cells.length > 4 ? cells[4] : 
                           cells.length > 3 ? cells[3] : null;

          if (actualCell) {
            const value = actualCell.textContent?.trim();
            if (value && value.length > 0 && value !== "-") {
              return value;
            }
          }
        }

        return null;
      },
      eventName,
      country
    );

    return actual;
  } catch (error: any) {
    silentLogger.error("TradingView scraper error:", error.message);
    return null;
  } finally {
    if (browser) {
      await browser.close();
    }
  }
}

export { scrapeTradingViewActual };