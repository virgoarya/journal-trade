# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (MongoDB)
DATABASE_URL=mongodb://localhost:27017/journal_trade

# Better Auth (Discord)
BETTER_AUTH_SECRET=your_super_secret_key_here_change_this
BETTER_AUTH_URL=http://localhost:5000
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_GUILD_ID=your_hunter_trades_guild_id

# AI (Google Gemini) - optional
GEMINI_API_KEY=your_gemini_api_key

# ===========================================
# MACRO TERMINAL API KEYS - LEADING INDICATORS
# ===========================================

# Finnhub - Real-time quotes, news, economic indicators
# Rate limit: 60 requests/minute
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage - Leading economic indicators, earnings, FX
# Rate limit: 5 requests/minute (free tier)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Twelve Data - Real-time market data, economic calendar
# Rate limit: 8 requests/minute (free tier)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# FRED API - Federal Reserve Economic Data (liquidity, yields)
# Rate limit: 30 requests/minute
FRED_API_KEY=your_fred_api_key_here

# Trading Economics - Economic calendar, indicators
# Rate limit: 10 requests/minute
TE_API_KEY=your_trading_economics_api_key_here

# ===========================================
# OPTIONAL OVERRIDES
# ===========================================

# CPI YoY override in percent (e.g., 3.2)
# MACRO_CPI_YOY_OVERRIDE=3.2

# Dev whitelist (comma-separated emails) — skip broker registration
# DEV_WHITELIST_EMAILS=developer@example.com